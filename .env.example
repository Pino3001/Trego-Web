# false = llamar al backend real (proxy Vite /api → localhost:8080)
VITE_USE_MOCK=false

# Opcional: base URL de la API (vacío = mismo origen + proxy en desarrollo)
# VITE_API_URL=

# Geoapify — autocompletado de direcciones (Solicitar alta restaurante)
# Obtener key gratis: https://myprojects.geoapify.com/ → Create project → API keys
VITE_GEOAPIFY_KEY=tu_api_key_aqui
